{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":configMigration",
    ":pinDevDependencies",
    "abandonments:recommended",
    "customManagers:githubActionsVersions",
    ":gomod",
    ":enableVulnerabilityAlerts",
    ":rebaseStalePrs",
    ":semanticCommits",
    ":semanticPrefixFixDepsChoreOthers"
  ],
  "timezone": "America/Chicago",
  "schedule": [
    "on monday"
  ],
  "automergeSchedule": [
    "at any time"
  ],
  "labels": [
    "dependencies"
  ],
  "dependencyDashboard": true,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 3,
  "minimumReleaseAge": "3 days",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Go tool versions in Dockerfiles and Makefile",
      "managerFilePatterns": [
        "/(^|/)Dockerfile[^/]*$/",
        "/(^|/)Makefile$/"
      ],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\n[^@]*@(?<currentValue>v[\\d.]+)"
      ],
      "versioningTemplate": "semver"
    }
  ],
  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths",
    "gomodMassage",
    "npmDedupe"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Pin Docker image digests in Dockerfiles for security",
      "matchDatasources": [
        "docker"
      ],
      "matchManagers": [
        "dockerfile"
      ],
      "pinDigests": true
    },
    {
      "description": "Docker-compose updates - disable digest pinning",
      "matchManagers": [
        "docker-compose"
      ],
      "pinDigests": false
    },
    {
      "description": "GitHub Actions updates - enable digest pinning",
      "matchManagers": [
        "github-actions"
      ],
      "pinDigests": true
    },
    {
      "description": "Group all non-major updates into a single PR",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "groupName": "all non-major dependencies",
      "automerge": true
    },
    {
      "description": "Major updates - separate PRs for review",
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "major"
      ],
      "automerge": false
    },
    {
      "description": "Security updates - immediate processing with highest priority",
      "matchPackageNames": [
        "*"
      ],
      "isVulnerabilityAlert": true,
      "addLabels": [
        "security"
      ],
      "prPriority": 10,
      "minimumReleaseAge": "0 days"
    }
  ]
}
