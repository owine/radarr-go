FROM golang:1.26.3-alpine@sha256:91eda9776261207ea25fd06b5b7fed8d397dd2c0a283e77f2ab6e91bfa71079d AS dev

# Install development tools
RUN apk add --no-cache \
    git \
    curl \
    bash \
    make \
    gcc \
    g++ \
    musl-dev \
    binutils \
    ca-certificates \
    tzdata

# Set timezone
ENV TZ=UTC

# Install air for hot reload
# renovate: datasource=go depName=github.com/air-verse/air
RUN go install github.com/air-verse/air@v1.65.1

# Install other development tools
# renovate: datasource=go depName=github.com/golang-migrate/migrate/v4
RUN go install github.com/golang-migrate/migrate/v4/cmd/migrate@v4.19.1

# Create app directory
WORKDIR /workspace

# Create non-root user for security
RUN adduser -D -s /bin/bash -u 1000 developer && \
    chown -R developer:developer /workspace && \
    chown -R developer:developer /go

# Switch to non-root user
USER developer

# Copy go mod files first for better layer caching
COPY --chown=developer:developer go.mod go.sum ./

# Download dependencies
RUN go mod download

# Copy source code
COPY --chown=developer:developer . .

# Create necessary directories
RUN mkdir -p data movies web/static web/templates

# Expose ports
EXPOSE 7878 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:7878/ping || exit 1

# Default command (can be overridden)
CMD ["air"]
